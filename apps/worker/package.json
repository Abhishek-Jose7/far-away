{
  "name": "worker",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:seed:local": "wrangler d1 execute DB --local --file=../../packages/database/migrations/0002_seed_mumbai.sql",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote --env production",
    "db:seed:prod": "wrangler d1 execute DB --remote --env production --file=../../packages/database/migrations/0002_seed_mumbai.sql"
  },
  "dependencies": {
    "@transitiq/scoring-engine": "workspace:*",
    "@transitiq/shared": "workspace:*",
    "@transitiq/types": "workspace:*",
    "hono": "^4.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240222.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.30.1"
  }
}
